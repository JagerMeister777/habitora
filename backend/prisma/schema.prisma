generator client {
  provider = "prisma-client-js"
}

// 本番MySQL切替時: provider を "mysql" に変更し DATABASE_URL を更新
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  nickname     String?
  registeredAt DateTime @default(now())
  isDeleted    Boolean  @default(false)
  posts        Post[]

  @@map("users")
}

model Post {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  text            String
  feelingScore    Int
  mode            String
  emotionKeywords String   @default("[]")
  isVisible       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@map("post")
}
